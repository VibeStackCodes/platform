{
  "buildCommand": "bun run build",
  "outputDirectory": "dist/client",
  "functions": {
    "app.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
