# ============================================================================
# VibeStack Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================================

# Supabase (Platform Instance)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Direct Database Connection (for Mastra agent memory — use pooler URL for serverless)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase Management API (for generating app databases)
SUPABASE_ACCESS_TOKEN=sbp_your-access-token
SUPABASE_ORG_ID=your-org-id

# AI Providers
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key

# Langfuse Observability (optional — wired via Mastra registry)
# LANGFUSE_PUBLIC_KEY=pk-lf-your-key
# LANGFUSE_SECRET_KEY=sk-lf-your-key
# LANGFUSE_BASEURL=https://cloud.langfuse.com

# Daytona Sandbox
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_SNAPSHOT_ID=your-snapshot-id

# Vercel Deployment
VERCEL_TOKEN=your-vercel-token
VERCEL_TEAM_ID=your-team-id
VERCEL_WILDCARD_PROJECT_ID=your-project-id

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-key\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_ORG=your-org

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Optional: Mock mode for E2E testing (bypasses auth and external services)
# VITE_MOCK_MODE=true
