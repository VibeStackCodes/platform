{
  "name": "platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n client,server \"vite\" \"bun --watch server/index.ts\"",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "biome format --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e:mock": "playwright test --project=mock",
    "test:e2e:real": "playwright test --project=real",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "mastra:dev": "mastra dev",
    "mastra:build": "mastra build",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "claude-md:update": "scripts/update-claude-md.sh"
  },
