{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "bun": "*"
  },
  "steps": {
    "install": {
      "commands": ["bun install --frozen-lockfile"]
    },
    "build": {
      "commands": ["echo 'Skipping client build — Railway runs server only'"]
    }
  },
  "deploy": {
    "startCommand": "bun run server/index.ts"
  }
}
