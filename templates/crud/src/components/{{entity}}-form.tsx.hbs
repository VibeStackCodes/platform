import { useState } from 'react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import type { Create{{pascalCase entity}}Input } from '@/types/{{entity}}';

interface {{pascalCase entity}}FormProps {
  onSubmit: (data: Create{{pascalCase entity}}Input) => Promise<void>;
  onCancel?: () => void;
  loading?: boolean;
}

export function {{pascalCase entity}}Form({ onSubmit, onCancel, loading }: {{pascalCase entity}}FormProps) {
  const [formData, setFormData] = useState<Partial<Create{{pascalCase entity}}Input>>({});
  const [error, setError] = useState('');

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setError('');
    try {
      await onSubmit(formData as Create{{pascalCase entity}}Input);
      setFormData({});
    } catch (err) {
      setError(err instanceof Error ? err.message : 'An error occurred');
    }
  };

  return (
    <form onSubmit={handleSubmit} className="space-y-4">
      {error && <div className="p-3 text-sm text-[hsl(var(--destructive))] bg-[hsl(var(--destructive))]/10 rounded-[var(--radius)]">{error}</div>}
{{#each fields}}
      <div className="space-y-2">
        <Label htmlFor="{{name}}">{{name}}</Label>
{{#if (eq type "boolean")}}
        <input id="{{name}}" type="checkbox" checked={!!formData["{{name}}"]} onChange={(e) => setFormData(prev => ({ ...prev, ["{{name}}"]: e.target.checked }))} className="h-4 w-4" />
{{else if (eq type "number")}}
        <Input id="{{name}}" type="number" value={formData["{{name}}"] ?? ''} onChange={(e) => setFormData(prev => ({ ...prev, ["{{name}}"]: Number(e.target.value) }))} {{#if required}}required{{/if}} />
{{else if (eq type "enum")}}
        <select id="{{name}}" value={(formData["{{name}}"] as string) ?? ''} onChange={(e) => setFormData(prev => ({ ...prev, ["{{name}}"]: e.target.value as Create{{pascalCase ../entity}}Input["{{name}}"] }))} className="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-base shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" {{#if required}}required{{/if}}>
          <option value="">Select {{name}}</option>
          {{#each enumValues}}<option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
{{else}}
        <Input id="{{name}}" type="text" value={(formData["{{name}}"] as string) ?? ''} onChange={(e) => setFormData(prev => ({ ...prev, ["{{name}}"]: e.target.value }))} {{#if required}}required{{/if}} />
{{/if}}
      </div>
{{/each}}
      <div className="flex gap-2">
        <Button type="submit" disabled={loading}>{loading ? 'Saving...' : 'Save'}</Button>
        {onCancel && <Button type="button" variant="outline" onClick={onCancel}>Cancel</Button>}
      </div>
    </form>
  );
}
