import { Routes, Route, Link, useLocation } from 'react-router';
{{#if hasAuth}}
import LoginPage from './pages/login';
import SignupPage from './pages/signup';
import { AuthGuard } from './components/auth-guard';
import { useAuth } from './hooks/use-auth';
{{/if}}
{{#if hasDashboard}}
import DashboardPage from './pages/dashboard';
{{/if}}
{{#each entities}}
import {{pascalCase this.pluralName}}Page from './pages/{{this.pluralName}}';
{{/each}}
{{#if hasMessaging}}
import { ChatPanel } from './components/chat-panel';
{{/if}}
import { {{#if hasDashboard}}LayoutDashboard, {{/if}}{{#if entities.length}}Table2, {{/if}}{{#if hasMessaging}}MessageSquare, {{/if}}{{#if hasAuth}}LogOut, {{/if}}Home } from 'lucide-react';

function Sidebar() {
  const location = useLocation();
  {{#if hasAuth}}
  const { signOut } = useAuth();
  {{/if}}

  return (
    <aside className="w-64 border-r border-border bg-card h-screen flex flex-col shrink-0">
      <div className="p-4 border-b border-border">
        <h1 className="font-bold text-lg tracking-tight">{{appName}}</h1>
      </div>
      <nav className="flex-1 p-2 space-y-1">
        {{#if hasDashboard}}
        <Link to="/" className={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${location.pathname === '/' ? 'bg-accent text-accent-foreground font-medium' : 'text-muted-foreground hover:bg-accent/50 hover:text-foreground'}`}>
          <LayoutDashboard className="h-4 w-4" />
          Dashboard
        </Link>
        {{else}}
        <Link to="/" className={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${location.pathname === '/' ? 'bg-accent text-accent-foreground font-medium' : 'text-muted-foreground hover:bg-accent/50 hover:text-foreground'}`}>
          <Home className="h-4 w-4" />
          Home
        </Link>
        {{/if}}
        {{#each entities}}
        <Link to="/{{this.pluralName}}" className={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${location.pathname === '/{{this.pluralName}}' ? 'bg-accent text-accent-foreground font-medium' : 'text-muted-foreground hover:bg-accent/50 hover:text-foreground'}`}>
          <Table2 className="h-4 w-4" />
          {{pascalCase this.pluralName}}
        </Link>
        {{/each}}
        {{#if hasMessaging}}
        <Link to="/messages" className={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors ${location.pathname === '/messages' ? 'bg-accent text-accent-foreground font-medium' : 'text-muted-foreground hover:bg-accent/50 hover:text-foreground'}`}>
          <MessageSquare className="h-4 w-4" />
          Messages
        </Link>
        {{/if}}
      </nav>
      {{#if hasAuth}}
      <div className="p-2 border-t border-border">
        <button onClick={() => signOut()} className="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-muted-foreground hover:bg-accent/50 hover:text-foreground w-full transition-colors">
          <LogOut className="h-4 w-4" />
          Sign out
        </button>
      </div>
      {{/if}}
    </aside>
  );
}

{{#if hasAuth}}
function ProtectedLayout() {
  return (
    <AuthGuard>
      <div className="flex h-screen">
        <Sidebar />
        <main className="flex-1 overflow-auto">
          <Routes>
            {{#if hasDashboard}}
            <Route path="/" element={<DashboardPage />} />
            {{else}}
            <Route path="/" element={<div className="flex items-center justify-center h-full"><h1 className="text-4xl font-bold">{{appName}}</h1></div>} />
            {{/if}}
            {{#each entities}}
            <Route path="/{{this.pluralName}}" element={<{{pascalCase this.pluralName}}Page />} />
            {{/each}}
            {{#if hasMessaging}}
            <Route path="/messages" element={<ChatPanel />} />
            {{/if}}
          </Routes>
        </main>
      </div>
    </AuthGuard>
  );
}
{{/if}}

export default function App() {
  return (
    <div className="min-h-screen bg-background text-foreground">
      <Routes>
        {{#if hasAuth}}
        <Route path="/login" element={<LoginPage />} />
        <Route path="/signup" element={<SignupPage />} />
        <Route path="/*" element={<ProtectedLayout />} />
        {{else}}
        <Route path="/*" element={
          <div className="flex h-screen">
            <Sidebar />
            <main className="flex-1 overflow-auto">
              <Routes>
                {{#if hasDashboard}}
                <Route path="/" element={<DashboardPage />} />
                {{else}}
                <Route path="/" element={<div className="flex items-center justify-center h-full"><h1 className="text-4xl font-bold">{{appName}}</h1></div>} />
                {{/if}}
                {{#each entities}}
                <Route path="/{{this.pluralName}}" element={<{{pascalCase this.pluralName}}Page />} />
                {{/each}}
                {{#if hasMessaging}}
                <Route path="/messages" element={<ChatPanel />} />
                {{/if}}
              </Routes>
            </main>
          </div>
        } />
        {{/if}}
      </Routes>
    </div>
  );
}
